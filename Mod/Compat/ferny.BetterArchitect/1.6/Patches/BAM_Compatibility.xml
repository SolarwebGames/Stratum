<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationAdd">
    <xpath>Defs/DesignationCategoryDef[defName="SolarWeb-Stratum-Roofs"]</xpath>
    <value>
      <modExtensions>
        <li Class="BetterArchitect.NestedCategoryExtension">
          <parentCategory>Structure</parentCategory>
        </li>
      </modExtensions>
    </value>
  </Operation>

  <Operation Class="PatchOperationConditional">
    <xpath>Defs/ThingDef[defName="SolarWeb-Stratum-SunLamp_Hanging"]/designationCategory</xpath>
    <match Class="PatchOperationReplace">
      <xpath>Defs/ThingDef[defName="SolarWeb-Stratum-SunLamp_Hanging"]/designationCategory</xpath>
      <value>
        <designationCategory>Ferny_Farming</designationCategory>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>Defs/ThingDef[defName="SolarWeb-Stratum-SunLamp_Hanging"]</xpath>
      <value>
        <designationCategory>Ferny_Farming</designationCategory>
      </value>
    </nomatch>
  </Operation>

