<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <StatDef>
    <defName>SolarWeb-Stratum-Insulation</defName>
    <label>insulation</label>
    <description>How well this material prevents heat from passing through. Higher values mean better temperature retention.</description>
    <category>Building</category>
    <defaultBaseValue>0.9</defaultBaseValue>
    <minValue>0</minValue>
    <maxValue>1</maxValue>
    <toStringStyle>PercentZero</toStringStyle>
    <showIfUndefined>false</showIfUndefined>
    <displayPriorityInCategory>2500</displayPriorityInCategory>
  </StatDef>

  <StatDef>
    <defName>SolarWeb-Stratum-Transparency</defName>
    <label>transparency</label>
    <description>The amount of light that passes through this roof.</description>
    <category>Building</category>
    <defaultBaseValue>0</defaultBaseValue>
    <minValue>0</minValue>
    <maxValue>1</maxValue>
    <toStringStyle>PercentZero</toStringStyle>
    <showIfUndefined>false</showIfUndefined>
    <displayPriorityInCategory>2501</displayPriorityInCategory>
  </StatDef>

  <StatDef>
    <defName>SolarWeb-Stratum-SolarOutput</defName>
    <label>solar output</label>
    <description>The direct power output generated by this roof tile when exposed to sunlight.</description>
    <category>Building</category>
    <defaultBaseValue>0</defaultBaseValue>
    <minValue>0</minValue>
    <maxValue>1000</maxValue>
    <toStringStyle>FloatOne</toStringStyle>
    <showIfUndefined>false</showIfUndefined>
    <displayPriorityInCategory>2502</displayPriorityInCategory>
  </StatDef>

  <StatDef>
    <defName>SolarWeb-Stratum-ThermalConductivity</defName>
    <label>thermal conductivity</label>
    <description>How quickly heat transfers through the roof.</description>
    <category>Building</category>
    <defaultBaseValue>0.1</defaultBaseValue>
    <minValue>0</minValue>
    <maxValue>10</maxValue>
    <toStringStyle>FloatTwo</toStringStyle>
    <showIfUndefined>false</showIfUndefined>
    <displayPriorityInCategory>2503</displayPriorityInCategory>
  </StatDef>
  
  <StatDef>
    <defName>SolarWeb-Stratum-StuffInsulationMultiplier</defName>
    <label>stuff insulation multiplier</label>
    <description>Multiplier applied to the insulation provided by the material used to build the roof.</description>
    <category>Building</category>
    <defaultBaseValue>1</defaultBaseValue>
    <minValue>0</minValue>
    <maxValue>10</maxValue>
    <toStringStyle>PercentZero</toStringStyle>
    <showIfUndefined>false</showIfUndefined>
    <displayPriorityInCategory>2504</displayPriorityInCategory>
  </StatDef>

  <StatDef>
    <defName>SolarWeb-Stratum-DamageThreshold</defName>
    <label>damage threshold</label>
    <description>The amount of damage the roof can take before being destroyed.</description>
    <category>Building</category>
    <defaultBaseValue>0</defaultBaseValue>
    <minValue>0</minValue>
    <maxValue>10000</maxValue>
    <toStringStyle>FloatOne</toStringStyle>
    <showIfUndefined>false</showIfUndefined>
    <displayPriorityInCategory>2505</displayPriorityInCategory>
  </StatDef>

  <StatDef>
    <defName>SolarWeb-Stratum-ArmorRating</defName>
    <label>armor rating</label>
    <description>The base armor rating of the roof against attacks.</description>
    <category>Building</category>
    <defaultBaseValue>0</defaultBaseValue>
    <minValue>0</minValue>
    <maxValue>10</maxValue>
    <toStringStyle>FloatTwo</toStringStyle>
    <showIfUndefined>false</showIfUndefined>
    <displayPriorityInCategory>2506</displayPriorityInCategory>
  </StatDef>
  
  <StatDef>
    <defName>SolarWeb-Stratum-StuffArmorMultiplier</defName>
    <label>stuff armor multiplier</label>
    <description>Multiplier applied to the armor rating provided by the material used to build the roof.</description>
    <category>Building</category>
    <defaultBaseValue>1</defaultBaseValue>
    <minValue>0</minValue>
    <maxValue>10</maxValue>
    <toStringStyle>PercentZero</toStringStyle>
    <showIfUndefined>false</showIfUndefined>
    <displayPriorityInCategory>2507</displayPriorityInCategory>
  </StatDef>

  <StatDef>
    <defName>SolarWeb-Stratum-TransitionSpeed</defName>
    <label>retraction speed</label>
    <description>The time it takes for a retractable roof to open or close one ring.</description>
    <category>Building</category>
    <defaultBaseValue>30</defaultBaseValue>
    <minValue>0</minValue>
    <maxValue>10000</maxValue>
    <toStringStyle>Integer</toStringStyle>
    <showIfUndefined>false</showIfUndefined>
    <displayPriorityInCategory>2508</displayPriorityInCategory>
    <formatString>{0} ticks</formatString>
  </StatDef>
</Defs>
