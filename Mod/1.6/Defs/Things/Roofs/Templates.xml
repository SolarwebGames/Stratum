<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef Name="SolarWeb_Stratum_RoofBuildableBase" ParentName="BuildingBase" Abstract="True">
    <category>Building</category>
    <thingClass>Building</thingClass>
    <label>roof template</label>
