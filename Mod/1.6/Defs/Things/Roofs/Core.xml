      <SolarWeb-Stratum-DamageThreshold>1</SolarWeb-Stratum-DamageThreshold>
      <SolarWeb-Stratum-ArmorRating>0.05</SolarWeb-Stratum-ArmorRating>
    </statBases>
    <costList>
