<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="SolarWeb_Stratum_RoofBuildableBase">
    <defName>SolarWeb-Stratum-RoofThatch_Buildable</defName>
    <label>primitive thatch roof</label>
    <description>A primitive roof made from bundled hay or straw. It is extremely cheap and quick to assemble, but it leaks air badly and offers almost no protection against extreme temperatures.</description>
    <statBases>
      <MaxHitPoints>40</MaxHitPoints>
      <WorkToBuild>100</WorkToBuild>
      <Beauty>-1.0</Beauty>
      <Flammability>1.5</Flammability>
      <SolarWeb-Stratum-Insulation>0.7</SolarWeb-Stratum-Insulation>
    </statBases>
    <uiOrder>2000</uiOrder>
    <constructionSkillPrerequisite>0</constructionSkillPrerequisite>
  </ThingDef>

  <SolarWeb.Stratum.Defs.StratumRoofDef>
    <defName>SolarWeb-Stratum-RoofThatch</defName>
    <label>primitive thatch roof</label>
    <description>A primitive roof made from bundled hay or straw. It is extremely cheap and quick to assemble, but it leaks air badly and offers almost no protection against extreme temperatures.</description>
    <isThickRoof>false</isThickRoof>
    <filthLeaving>Filth_RubbleBuilding</filthLeaving>
    <soundPunchThrough>Pawn_Melee_Punch_HitBuilding_Wood</soundPunchThrough>
    <modExtensions>
      <li Class="SolarWeb.Stratum.DefModExtensions.BuildableRoofExtension">
        <buildableDef>SolarWeb-Stratum-RoofThatch_Buildable</buildableDef>
        <graphicData>
          <texPath>Roofs/Thatch</texPath>
            <isSeamless>true</isSeamless>
        </graphicData>
        <designationCategory>SolarWeb-Stratum-Roofs</designationCategory>
        <transparency>0.2</transparency>
        <glassTint>(0.4, 0.3, 0.1)</glassTint>
        <thermalConductivity>0.3</thermalConductivity>
        <isAirtight>false</isAirtight>
      </li>
      <li Class="SolarWeb.Kalyphos.DefModExtensions.StructuralProperties" MayRequire="SolarWeb.Kalyphos">
        <Name>Primitive Thatch Roof</Name>
        <Properties>
          <ThermalCapacity>200</ThermalCapacity>
          <ThermalConductivity>0.3</ThermalConductivity>
          <FaceGasPermeability>0.8</FaceGasPermeability>
          <MaxPressureDeltaKpa>10</MaxPressureDeltaKpa>
        </Properties>
      </li>
    </modExtensions>
  </SolarWeb.Stratum.Defs.StratumRoofDef>

