  <ThingDef ParentName="SolarWeb_Stratum_RoofBuildableBase">
    <defName>SolarWeb-Stratum-ReinforcedGlassPanel_Buildable</defName>
    <label>reinforced glass panel</label>
    <description>Thick, lead-lined glass panels held in a steel frame. Allows viewing the stars while maintaining an airtight seal, though it is less insulating and strong than solid hull plates.</description>
    <statBases>
      <MaxHitPoints>150</MaxHitPoints>
      <WorkToBuild>400</WorkToBuild>
      <Beauty>2.0</Beauty>
      <SolarWeb-Stratum-Insulation>0.5</SolarWeb-Stratum-Insulation>
      <SolarWeb-Stratum-Transparency>0.8</SolarWeb-Stratum-Transparency>
      <SolarWeb-Stratum-ThermalConductivity>0.5</SolarWeb-Stratum-ThermalConductivity>
      <SolarWeb-Stratum-DamageThreshold>5</SolarWeb-Stratum-DamageThreshold>
      <SolarWeb-Stratum-ArmorRating>0.20</SolarWeb-Stratum-ArmorRating>
    </statBases>
    <costList>
      <Steel>3</Steel>
      <Plasteel>3</Plasteel>
    </costList>
    <uiOrder>2230</uiOrder>
    <constructionSkillPrerequisite>4</constructionSkillPrerequisite>
    <researchPrerequisites>
      <li>AdvancedFabrication</li>
    </researchPrerequisites>
  </ThingDef>

