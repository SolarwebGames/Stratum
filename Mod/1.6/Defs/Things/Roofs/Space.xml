  <ThingDef ParentName="SolarWeb_Stratum_RoofBuildableBase">
    <defName>SolarWeb-Stratum-RetractableRoof_Buildable</defName>
    <label>heavy retractable canopy</label>
    <description>A motorized, high-tech armored canopy segment. Retracts outward when authorized by a connected console. Requires extreme power when transitioning.</description>
    <statBases>
      <MaxHitPoints>180</MaxHitPoints>
      <WorkToBuild>600</WorkToBuild>
      <Beauty>2.0</Beauty>
      <SolarWeb-Stratum-Insulation>0.90</SolarWeb-Stratum-Insulation>
      <SolarWeb-Stratum-ThermalConductivity>0.10</SolarWeb-Stratum-ThermalConductivity>
      <SolarWeb-Stratum-DamageThreshold>10</SolarWeb-Stratum-DamageThreshold>
      <SolarWeb-Stratum-ArmorRating>0.25</SolarWeb-Stratum-ArmorRating>
      <SolarWeb-Stratum-TransitionSpeed>120</SolarWeb-Stratum-TransitionSpeed>
    </statBases>
    <costList>
      <Steel>10</Steel>
      <Plasteel>5</Plasteel>
      <ComponentIndustrial>1</ComponentIndustrial>
    </costList>
    <uiOrder>2240</uiOrder>
    <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
    <researchPrerequisites>
      <li>MicroelectronicsBasics</li>
    </researchPrerequisites>
  </ThingDef>

