<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="SolarWeb_Stratum_RoofBuildableBase">
    <defName>SolarWeb-Stratum-HullPlating_Buildable</defName>
    <label>hull plating</label>
    <description>Simple, airtight metal plates used for basic spacecraft hull construction. It is perfectly impermeable but lacks the structural reinforcement of higher-tier plating.</description>
    <statBases>
      <MaxHitPoints>150</MaxHitPoints>
      <WorkToBuild>300</WorkToBuild>
      <Beauty>0.5</Beauty>
      <SolarWeb-Stratum-Insulation>0.95</SolarWeb-Stratum-Insulation>
      <SolarWeb-Stratum-ThermalConductivity>0.05</SolarWeb-Stratum-ThermalConductivity>
      <SolarWeb-Stratum-DamageThreshold>8</SolarWeb-Stratum-DamageThreshold>
      <SolarWeb-Stratum-ArmorRating>0.35</SolarWeb-Stratum-ArmorRating>
    </statBases>
    <costList>
      <Steel>8</Steel>
    </costList>
    <uiOrder>2200</uiOrder>
    <constructionSkillPrerequisite>4</constructionSkillPrerequisite>
    <researchPrerequisites>
      <li>Fabrication</li>
    </researchPrerequisites>
  </ThingDef>

  <SolarWeb.Stratum.Defs.StratumRoofDef>
    <defName>SolarWeb-Stratum-HullPlating</defName>
    <label>hull plating</label>
    <description>Simple, airtight metal plates used for basic spacecraft hull construction. It is perfectly impermeable but lacks the structural reinforcement of higher-tier plating.</description>
    <isThickRoof>false</isThickRoof>
    <filthLeaving>Filth_RubbleBuilding</filthLeaving>
    <soundPunchThrough>PunchThroughRoofMetal</soundPunchThrough>
    <modExtensions>
      <li Class="SolarWeb.Stratum.DefModExtensions.BuildableRoofExtension">
        <buildableDef>SolarWeb-Stratum-HullPlating_Buildable</buildableDef>
        <graphicData>
          <texPath>Roofs/GenericTile</texPath>
          <isSeamless>true</isSeamless>
          <color>(0.37, 0.37, 0.37)</color>
          <edgeData>
            <color>(0.3, 0.3, 0.3)</color>
          </edgeData>
        </graphicData>
        <designationCategory>SolarWeb-Stratum-Roofs</designationCategory>
      </li>
      <li Class="SolarWeb.Kalyphos.DefModExtensions.StructuralProperties" MayRequire="SolarWeb.Kalyphos">
        <Name>Hull Plating</Name>
        <Properties>
          <ThermalCapacity>1500</ThermalCapacity>
          <ThermalConductivity>0.05</ThermalConductivity>
          <FaceGasPermeability>0</FaceGasPermeability>
          <MaxPressureDeltaKpa>1200</MaxPressureDeltaKpa>
        </Properties>
      </li>
    </modExtensions>
  </SolarWeb.Stratum.Defs.StratumRoofDef>

  <ThingDef ParentName="SolarWeb_Stratum_RoofBuildableBase">
    <defName>SolarWeb-Stratum-ReinforcedHullPlating_Buildable</defName>
    <label>reinforced hull plating</label>
    <description>Heavy-duty, double-layered metal plates with internal structural supports. Designed to withstand significant pressure differentials and micrometeoroid impacts.</description>
    <statBases>
      <MaxHitPoints>325</MaxHitPoints>
      <WorkToBuild>400</WorkToBuild>
      <Beauty>1.0</Beauty>
      <SolarWeb-Stratum-Insulation>0.98</SolarWeb-Stratum-Insulation>
      <SolarWeb-Stratum-ThermalConductivity>0.02</SolarWeb-Stratum-ThermalConductivity>
      <SolarWeb-Stratum-DamageThreshold>15</SolarWeb-Stratum-DamageThreshold>
      <SolarWeb-Stratum-ArmorRating>0.50</SolarWeb-Stratum-ArmorRating>
    </statBases>
    <costList>
      <Steel>12</Steel>
      <Plasteel>2</Plasteel>
    </costList>
    <uiOrder>2210</uiOrder>
    <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
    <researchPrerequisites>
      <li>Fabrication</li>
    </researchPrerequisites>
  </ThingDef>

