  <ThingDef ParentName="SolarWeb_Stratum_RoofBuildableBase">
    <defName>SolarWeb-Stratum-SolarHullPlate_Buildable</defName>
    <label>reinforced solar hull plating</label>
    <description>Top-tier orbital roofing. Combines the structural integrity of reinforced hull plating with integrated solar collection cells. While expensive, it provides power while serving as a high-pressure seal.</description>
    <statBases>
      <MaxHitPoints>300</MaxHitPoints>
      <WorkToBuild>500</WorkToBuild>
      <Beauty>1.0</Beauty>
      <SolarWeb-Stratum-Insulation>0.98</SolarWeb-Stratum-Insulation>
      <SolarWeb-Stratum-SolarOutput>50</SolarWeb-Stratum-SolarOutput>
      <SolarWeb-Stratum-ThermalConductivity>0.02</SolarWeb-Stratum-ThermalConductivity>
      <SolarWeb-Stratum-DamageThreshold>12</SolarWeb-Stratum-DamageThreshold>
      <SolarWeb-Stratum-ArmorRating>0.45</SolarWeb-Stratum-ArmorRating>
    </statBases>
    <costList>
      <Steel>18</Steel>
      <Plasteel>4</Plasteel>
    </costList>
    <uiOrder>2220</uiOrder>
    <constructionSkillPrerequisite>8</constructionSkillPrerequisite>
  </ThingDef>

