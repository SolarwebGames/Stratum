  <ThingDef ParentName="BuildingBase">
    <defName>SolarWeb-Stratum-RetractableRoofConsole</defName>
    <label>retractable canopy console</label>
    <description>A command console that links to all retractable armored canopy segments in its room. Requires 200W of standby power, but draws 1500W while actively opening or closing the canopy. Pawns can operate this console to trigger a 1-second authorization sequence.</description>
    <thingClass>SolarWeb.Stratum.Things.RetractableRoofConsole</thingClass>
    <tickerType>Normal</tickerType>
    <graphicData>
      <texPath>Things/Building/Misc/AncientTerminal/AncientTerminal</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawOffsetNorth>(0,0,0.9)</drawOffsetNorth>
      <drawOffsetSouth>(0,0,-0.9)</drawOffsetSouth>
      <drawOffsetWest>(-0.9,0,0)</drawOffsetWest>
      <drawOffsetEast>(0.9,0,0)</drawOffsetEast>
      <damageData>
        <enabled>false</enabled>
      </damageData>
      <drawSize>(0.5,0.5)</drawSize>
    </graphicData>
    <altitudeLayer>BuildingOnTop</altitudeLayer>
    <passability>Standable</passability>
    <terrainAffordanceNeeded IsNull="True" />
    <pathCost>0</pathCost>
    <statBases>
      <MaxHitPoints>50</MaxHitPoints>
      <WorkToBuild>3000</WorkToBuild>
      <Mass>10</Mass>
    </statBases>
    <size>(1,1)</size>
    <costList>
      <Steel>150</Steel>
      <Plasteel>15</Plasteel>
      <ComponentIndustrial>3</ComponentIndustrial>
    </costList>
    <altitudeLayer>BuildingOnTop</altitudeLayer>
    <statBases>
      <MarketValue>200</MarketValue>
      <MaxHitPoints>80</MaxHitPoints>
      <WorkToBuild>2000</WorkToBuild>
      <Mass>8</Mass>
    </statBases>
    <minifiedDrawOffset>(0, 0, 0.2)</minifiedDrawOffset>
    <building>
      <isEdifice>false</isEdifice>
      <isAttachment>true</isAttachment>
      <expandHomeArea>false</expandHomeArea>
    </building>
    <placeWorkers>
      <li>Placeworker_AttachedToWall</li>
    </placeWorkers>
    <designationCategory>SolarWeb-Stratum-Roofs</designationCategory>
    <researchPrerequisites>
      <li>MicroelectronicsBasics</li>
      <li>Fabrication</li>
    </researchPrerequisites>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>200</basePowerConsumption>
      </li>
      <li Class="CompProperties_Flickable" />
    </comps>
  </ThingDef>

</Defs>