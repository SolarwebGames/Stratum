<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="LampBase">
    <defName>SolarWeb-Stratum-SunLamp_Hanging</defName>
    <label>hanging sun lamp</label>
    <description>An industrial lamp which lights an area brightly enough to grow crops, but consumes a huge amount of power. Designed to hang from the underside of a roof ceiling.</description>
    <thingClass>Building_SunLamp</thingClass>
    <graphicData>
      <texPath>Things/Building/Production/LampSun</texPath>
    </graphicData>
    <defaultPlacingRot>South</defaultPlacingRot>
    <blockWind>true</blockWind>
    <tickerType>Rare</tickerType>
    <passability>Standable</passability>
    <pathCost>0</pathCost>
    <building>
      <isEdifice>false</isEdifice>
    </building>
    <statBases>
      <WorkToBuild>330</WorkToBuild>
      <Mass>4.5</Mass>
    </statBases>
    <costList>
      <Steel>60</Steel>
    </costList>
    <uiOrder>2995</uiOrder>
    <comps>
      <li Class="CompProperties_Glower">
        <overlightRadius>7.0</overlightRadius>
        <glowRadius>14</glowRadius>
        <glowColor>(370,370,370,0)</glowColor>
      </li>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <shortCircuitInRain>true</shortCircuitInRain>
        <basePowerConsumption>3000</basePowerConsumption>
      </li>
      <li Class="CompProperties_Schedule">
        <startTime>0.25</startTime>
        <endTime>0.8</endTime>
        <offMessage>Off for plant resting period</offMessage>
      </li>
      <li Class="CompProperties_HeatPusher">
        <compClass>CompHeatPusherPowered</compClass>
        <heatPerSecond>3</heatPerSecond>
      </li>
    </comps>
    <specialDisplayRadius>5.8</specialDisplayRadius>
    <placeWorkers Inherit="false">
      <li>SolarWeb.Stratum.AI.PlaceWorkers.OnRoof</li>
      <li>PlaceWorker_GlowRadius</li>
    </placeWorkers>
    <modExtensions>
      <li Class="SolarWeb.Stratum.DefModExtensions.RoofBuilding">
        <attachmentType>Hanging</attachmentType>
        <minifyOnRoofLoss>true</minifyOnRoofLoss>
        <destroyOnRoofLoss>false</destroyOnRoofLoss>
      </li>
    </modExtensions>
    <researchPrerequisites>
      <li>Electricity</li>
    </researchPrerequisites>
  </ThingDef>

  <ThingDef ParentName="BuildingBase">
    <defName>SolarWeb-Stratum-FireSprinkler</defName>
    <label>hanging fire sprinkler</label>
    <description>An automated fire sprinkler system that hangs from the ceiling. When fire is detected, it discharges firefoam to extinguish them. Uses chemfuel to spray the foam and must be recharged after going off.</description>
    <thingClass>Building</thingClass>
    <graphicData>
      <texPath>Things/Building/Misc/FirefoamPopper</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1,1)</drawSize>
    </graphicData>
    <defaultPlacingRot>South</defaultPlacingRot>
    <rotatable>false</rotatable>
    <altitudeLayer>Building</altitudeLayer>
    <passability>Standable</passability>
    <pathCost>0</pathCost>
    <building>
      <isEdifice>false</isEdifice>
    </building>
    <statBases>
      <MaxHitPoints>80</MaxHitPoints>
      <WorkToBuild>1500</WorkToBuild>
      <Flammability>0</Flammability>
      <Mass>2.5</Mass>
    </statBases>
    <costList>
      <Steel>75</Steel>
      <ComponentIndustrial>1</ComponentIndustrial>
    </costList>
    <comps>
      <li Class="CompProperties_Refuelable">
        <fuelCapacity>30.0</fuelCapacity>
        <fuelFilter>
          <thingDefs>
            <li>Chemfuel</li>
          </thingDefs>
        </fuelFilter>
        <fuelLabel>Chemfuel</fuelLabel>
        <fuelGizmoLabel>Chemfuel</fuelGizmoLabel>
        <consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
        <autoRefuelPercent>1</autoRefuelPercent>
        <showFuelGizmo>true</showFuelGizmo>
        <drawOutOfFuelOverlay>false</drawOutOfFuelOverlay>
        <showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
        <canEjectFuel>false</canEjectFuel>
        <drawFuelGaugeInMap>false</drawFuelGaugeInMap>
      </li>
      <li Class="CompProperties_Explosive">
        <explosiveRadius>0</explosiveRadius>
        <explosiveExpandPerFuel>0.8333</explosiveExpandPerFuel>
        <explosiveDamageType>Extinguish</explosiveDamageType>
        <startWickHitPointsPercent>-1</startWickHitPointsPercent>
        <chanceNeverExplodeFromDamage>1</chanceNeverExplodeFromDamage>
        <postExplosionSpawnThingDef>Filth_FireFoam</postExplosionSpawnThingDef>
        <postExplosionSpawnChance>1</postExplosionSpawnChance>
        <postExplosionSpawnThingCount>1</postExplosionSpawnThingCount>
        <applyDamageToExplosionCellsNeighbors>true</applyDamageToExplosionCellsNeighbors>
        <explosionEffect>ExtinguisherExplosion</explosionEffect>
        <explosionSound>Explosion_FirefoamPopper</explosionSound>
        <wickTicks>0</wickTicks>
        <destroyThingOnExplosionSize>9999</destroyThingOnExplosionSize>
      </li>
      <li Class="CompProperties_ProximityFuse">
        <target>Fire</target>
        <radius>5</radius>
      </li>
    </comps>
    <tickerType>Normal</tickerType>
    <designationCategory>Misc</designationCategory>
    <uiOrder>2850</uiOrder>
    <constructEffect>ConstructMetal</constructEffect>
    <minifiedDef>MinifiedThing</minifiedDef>
    <thingCategories>
      <li>BuildingsFurniture</li>
    </thingCategories>
    <placeWorkers>
      <li>SolarWeb.Stratum.AI.PlaceWorkers.OnRoof</li>
    </placeWorkers>
    <modExtensions>
      <li Class="SolarWeb.Stratum.DefModExtensions.RoofBuilding">
        <attachmentType>Hanging</attachmentType>
        <minifyOnRoofLoss>true</minifyOnRoofLoss>
        <destroyOnRoofLoss>false</destroyOnRoofLoss>
      </li>
    </modExtensions>
    <researchPrerequisites>
      <li>Firefoam</li>
    </researchPrerequisites>
  </ThingDef>

