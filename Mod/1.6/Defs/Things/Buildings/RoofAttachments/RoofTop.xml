<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>SolarWeb-Stratum-LightningRod</defName>
    <label>rooftop lightning rod</label>
    <description>A copper rod mounted on top of a roof. Attracts lightning strikes within the colony, safely converting the electrical discharge into power stored directly in connected batteries.</description>
    <thingClass>Building</thingClass>
    <graphicData>
      <texPath>Things/Building/Misc/FirefoamPopper</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.5, 1)</drawSize>
      <color>(55, 55, 55)</color>
    </graphicData>
    <rotatable>false</rotatable>
    <altitudeLayer>Building</altitudeLayer>
    <passability>Standable</passability>
    <pathCost>0</pathCost>
    <building>
      <isEdifice>false</isEdifice>
    </building>
    <statBases>
      <MaxHitPoints>150</MaxHitPoints>
      <WorkToBuild>1000</WorkToBuild>
      <Flammability>0</Flammability>
    </statBases>
    <costList>
      <Steel>50</Steel>
      <ComponentIndustrial>1</ComponentIndustrial>
    </costList>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTransmitter</compClass>
        <basePowerConsumption>0</basePowerConsumption>
        <transmitsPower>true</transmitsPower>
      </li>
    </comps>
    <designationCategory>Power</designationCategory>
    <uiOrder>2110</uiOrder>
    <constructEffect>ConstructMetal</constructEffect>
    <placeWorkers>
      <li>SolarWeb.Stratum.AI.PlaceWorkers.OnRoof</li>
    </placeWorkers>
    <modExtensions>
      <li Class="SolarWeb.Stratum.DefModExtensions.RoofBuilding">
        <attachmentType>Rooftop</attachmentType>
        <minifyOnRoofLoss>false</minifyOnRoofLoss>
        <destroyOnRoofLoss>false</destroyOnRoofLoss>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="BuildingBase">
    <defName>SolarWeb-Stratum-WindTurbine_Rooftop</defName>
    <label>rooftop wind turbine</label>
    <description>A compact vertical-axis wind turbine mounted on a roof. Generates power based on the map's wind speed, without requiring clear ground paths.</description>
    <thingClass>Building</thingClass>
    <graphicData>
      <texPath>Things/Building/Power/WindTurbine/WindTurbineBody</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(3,1)</drawSize>
    </graphicData>
    <rotatable>false</rotatable>
    <altitudeLayer>Building</altitudeLayer>
    <passability>Standable</passability>
    <pathCost>0</pathCost>
    <size>(3,1)</size>
    <building>
      <isEdifice>false</isEdifice>
    </building>
    <statBases>
      <MaxHitPoints>120</MaxHitPoints>
      <WorkToBuild>1500</WorkToBuild>
      <Flammability>0.1</Flammability>
    </statBases>
    <costList>
      <Steel>100</Steel>
      <ComponentIndustrial>3</ComponentIndustrial>
    </costList>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>SolarWeb.Stratum.ThingComps.RooftopWindTurbine</compClass>
        <basePowerConsumption>0</basePowerConsumption>
        <transmitsPower>true</transmitsPower>
      </li>
    </comps>
    <designationCategory>Power</designationCategory>
    <uiOrder>2120</uiOrder>
    <constructEffect>ConstructMetal</constructEffect>
    <placeWorkers>
      <li>SolarWeb.Stratum.AI.PlaceWorkers.OnRoof</li>
    </placeWorkers>
    <modExtensions>
      <li Class="SolarWeb.Stratum.DefModExtensions.RoofBuilding">
        <attachmentType>Rooftop</attachmentType>
        <minifyOnRoofLoss>false</minifyOnRoofLoss>
        <destroyOnRoofLoss>true</destroyOnRoofLoss>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="BuildingBase">
    <defName>SolarWeb-Stratum-RooftopScannerBooster</defName>
    <label>rooftop scan booster</label>
    <description>A high-gain tracking dish antenna mounted on the roof. By linking with advanced scanning arrays like long-range mineral scanners and orbital signals consoles, it boosts their scanning and signal acquisition speeds. Must be powered to function.</description>
    <thingClass>Building</thingClass>
    <graphicData>
      <texPath>Things/Building/Ruins/AncientLamppost</texPath>
      <graphicClass>Graphic_Random</graphicClass>
      <drawSize>(1,1)</drawSize>
      <color>(160, 160, 180)</color>
    </graphicData>
    <rotatable>false</rotatable>
    <altitudeLayer>Building</altitudeLayer>
    <passability>Standable</passability>
    <pathCost>0</pathCost>
    <building>
      <isEdifice>false</isEdifice>
    </building>
    <statBases>
      <MaxHitPoints>120</MaxHitPoints>
      <WorkToBuild>2500</WorkToBuild>
      <Flammability>0.1</Flammability>
    </statBases>
    <costList>
      <Steel>80</Steel>
      <Plasteel>15</Plasteel>
      <ComponentIndustrial>4</ComponentIndustrial>
    </costList>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>120</basePowerConsumption>
        <transmitsPower>true</transmitsPower>
      </li>
      <li>
        <compClass>SolarWeb.Stratum.ThingComps.ScannerBooster</compClass>
      </li>
    </comps>
    <designationCategory>Misc</designationCategory>
    <uiOrder>2860</uiOrder>
    <constructEffect>ConstructMetal</constructEffect>
    <placeWorkers>
      <li>SolarWeb.Stratum.AI.PlaceWorkers.OnRoof</li>
      <li>SolarWeb.Stratum.AI.PlaceWorkers.PlaceWorker_ScannerBooster</li>
    </placeWorkers>
    <modExtensions>
      <li Class="SolarWeb.Stratum.DefModExtensions.RoofBuilding">
        <attachmentType>Rooftop</attachmentType>
        <minifyOnRoofLoss>false</minifyOnRoofLoss>
        <destroyOnRoofLoss>true</destroyOnRoofLoss>
      </li>
      <li Class="SolarWeb.Stratum.DefModExtensions.ScannerBooster">
        <scanSpeedMultiplier>1.5</scanSpeedMultiplier>
        <range>20</range>
      </li>
    </modExtensions>
    <researchPrerequisites>
      <li>MicroelectronicsBasics</li>
    </researchPrerequisites>
  </ThingDef>

</Defs>